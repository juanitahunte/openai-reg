## OpenAI Auto Register - Environment

# Optional
OPENAI_SSL_VERIFY=1
SKIP_NET_CHECK=0
TOKEN_OUTPUT_DIR=

# Gmail IMAP (required for auto OTP fetch)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=1
IMAP_USER=mygmail@gmail.com
IMAP_PASSWORD=aaaa bbbb cccc dddd
IMAP_FOLDER=INBOX
IMAP_TIMEOUT_SECONDS=180
IMAP_POLL_SECONDS=3
IMAP_LOOKBACK_SECONDS=900
